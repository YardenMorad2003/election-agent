# Agentic Electoral Analyst — environment template
# Copy this file to `.env` and fill in real values. .env is gitignored.

# ── Required ───────────────────────────────────────────────────────────
# OpenAI API key. Used by every routing config and every web-search
# synthesis call. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional ───────────────────────────────────────────────────────────
# PostgreSQL connection string. If set, db.py uses Postgres as the
# primary DB and falls back to the bundled elections.db SQLite file
# only on connection failure. If unset, SQLite is used directly.
# DATABASE_URL=postgresql://user:password@localhost:5432/election_agent

# ── Streamlit Cloud note ───────────────────────────────────────────────
# When deploying to Streamlit Cloud, set the same vars under
# "Manage app → Settings → Secrets" instead of this file. The Streamlit
# secrets store overrides .env (agent.py:16-20 reads st.secrets first).
